# 藏鋒 ZF_TrendPicking 環境變數範例
# 完整初始化教學見 HANDOVER.md
#
# 【單一環境】複製為 .env 並填入實際值：  cp .env.example .env
# 【多環境】  每套帳號各建一份，例如：
#     cp .env.example .env.self     # 你自己的 token/Sheet/GitHub
#     cp .env.example .env.client   # 甲方的 token/Sheet/GitHub
#   切換用： source scripts/use-env.sh self   （會自動設好 app 設定 + gh/git 帳號）
#   不設 APP_ENV 時程式預設讀 .env（向後相容）

# ===== 台股 =====
# FinMind API Token（https://finmindtrade.com/ 註冊取得；美股不需要）
FINMIND_TOKEN=your_finmind_token_here

# 台股 Google Sheet ID（從 Sheet 網址 /d/【這段】/edit 取得）
SHEET_ID_COMPANY_MASTER=your_sheet_id_here
SHEET_ID_TW_VCP=your_sheet_id_here
SHEET_ID_TW_SANXIAN=your_sheet_id_here
SHEET_ID_VERIFICATION=your_sheet_id_here

# ===== 美股 =====
# 美股 Google Sheet ID
US_SHEET_ID_COMPANY_MASTER=your_sheet_id_here
US_SHEET_ID_VCP=your_sheet_id_here
US_SHEET_ID_SANXIAN=your_sheet_id_here
US_SHEET_ID_VERIFICATION=your_sheet_id_here

# 美股資料源：free=yfinance（免費，免金鑰），保持 free 即可
# 其他選項 polygon/eodhd/twelvedata 為日後付費擴充預留，需對應 API key
US_DATA_PROVIDER=free

# ===== 共用 =====
# Google 服務帳號金鑰路徑（台股美股共用同一把）
GOOGLE_CREDENTIALS_PATH=credentials.json

# 日誌級別 (DEBUG/INFO/WARNING/ERROR)
LOG_LEVEL=INFO

# ===== GitHub（多環境切換用，單一環境可留空）=====
# 同一個 GitHub 帳號、不同 repo 的情境——不需要 token，只要指定目標 repo 與 remote
# 此環境的目標 repo（gh run list / gh workflow run 會自動對它操作）
GH_REPO=your_github_account/ZF_TrendPicking
# git push 用的 remote 名稱（你自己的=origin；甲方開的 repo 自訂一個，如 client）
GIT_REMOTE=origin
